<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.javaee.ex08.mapper.PublisherMapper">
    <select id="findPublishers" resultType="com.javaee.ex08.po.Publisher">
        select * from publisher;
    </select>

    <select id="findByName" parameterType="string" resultType="com.javaee.ex08.po.Publisher">
        select * from publisher where pub_name = #{name}
    </select>

    <select id="findByContacter" parameterType="string" resultType="com.javaee.ex08.po.Publisher">
        select * from publisher where contacter = #{contacter}
    </select>
</mapper>
